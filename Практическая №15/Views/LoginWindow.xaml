<Window x:Class="Практическая__15.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Практическая__15.Views"
        mc:Ignorable="d"
        Background="#dfeaeb"
        Title="Вход в систему" 
        Height="500" 
        Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <StackPanel VerticalAlignment="Center" 
                    HorizontalAlignment="Center" 
                    Width="350">

            <TextBlock Text="Магазин электроники" 
                       FontSize="28" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"
                       Foreground="#333333"/>

            <Border Background="White" 
                    CornerRadius="10" 
                    Padding="25"
                    Margin="0,0,0,20"
                    Effect="{StaticResource MaterialDesignElevationShadow4}">
                <StackPanel>
                    <TextBlock Text="Вход для менеджера" 
                               FontSize="18" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"
                               Foreground="#00c4b4"/>

                    <TextBlock Text="Пин-код:" 
                               FontSize="14" 
                               Margin="0,0,0,5"/>

                    <PasswordBox x:Name="PinCodeBox" 
                                 Height="35"
                                 FontSize="14"
                                 Style="{StaticResource MaterialDesignPasswordBox}"/>

                    <Button Content="Войти как менеджер" 
                            Click="ManagerLogin_Click"
                            Background="#00c4b4"
                            Foreground="White"
                            Height="40"
                            FontSize="14"
                            FontWeight="Bold"
                            Margin="0,15,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="White" 
                    CornerRadius="10" 
                    Padding="25"
                    Effect="{StaticResource MaterialDesignElevationShadow4}">
                <StackPanel>
                    <TextBlock Text="Вход для посетителя" 
                               FontSize="18" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"
                               Foreground="#00b4c4"/>

                    <Button Content="Войти как посетитель" 
                            Click="GuestLogin_Click"
                            Background="#00b4c4"
                            Foreground="White"
                            Height="40"
                            FontSize="14"
                            FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>