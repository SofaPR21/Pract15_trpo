<Window x:Class="Практическая__15.Views.ManageTagsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление тегами" 
        Height="500" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#dfeaeb"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Теги товаров" 
                   FontSize="18" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"
                   Foreground="#00c4b4"/>

        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ListView Grid.Row="1" 
                      x:Name="listTags" 
                      SelectionMode="Single"
                      Background="White"
                      BorderBrush="#E0E0E0"
                      BorderThickness="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" Width="80" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Название" Width="340" DisplayMemberBinding="{Binding Name}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </ScrollViewer>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Margin="0,15,0,0">
            <Button Content="Добавить" 
                    Click="Add_Click" 
                    Width="100" 
                    Height="35"
                    Margin="5"
                    Background="#00c4b4" 
                    Foreground="White"
                    FontWeight="Bold"/>
            <Button Content="Редактировать" 
                    Click="Edit_Click" 
                    Width="140" 
                    Height="35"
                    Margin="5"
                    Background="#E0E0E0"
                    Foreground="#333333"
                    FontWeight="Bold"/>
            <Button Content="Удалить" 
                    Click="Delete_Click" 
                    Width="90" 
                    Height="35"
                    Margin="5"
                    Background="#E0E0E0"
                    Foreground="#333333"
                    FontWeight="Bold"/>
            <Button Content="Закрыть" 
                    Click="Close_Click" 
                    Width="90" 
                    Height="35"
                    Margin="5"
                    Background="#E0E0E0"
                    Foreground="#333333"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>