<Window x:Class="Практическая__15.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxml.net/winfx/xaml/themes"
        xmlns:validation="clr-namespace:Практическая__15.Validation"
        xmlns:local="clr-namespace:Практическая__15"
        mc:Ignorable="d"
        Height="700" 
        Width="1200"
        MinHeight="600" 
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#dfeaeb"
        Title="Магазин электроники">

    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Stock}" Value="0">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="Background" Value="#FFF5F5"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Stock}" Value="1">
                    <Setter Property="BorderBrush" Value="#ffd129"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Stock}" Value="2">
                    <Setter Property="BorderBrush" Value="#ffd129"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Stock}" Value="3">
                    <Setter Property="BorderBrush" Value="#ffd129"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Stock}" Value="4">
                    <Setter Property="BorderBrush" Value="#ffd129"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Stock}" Value="5">
                    <Setter Property="BorderBrush" Value="#ffd129"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Stock}" Value="6">
                    <Setter Property="BorderBrush" Value="#ffd129"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Stock}" Value="7">
                    <Setter Property="BorderBrush" Value="#ffd129"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Stock}" Value="8">
                    <Setter Property="BorderBrush" Value="#ffd129"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Stock}" Value="9">
                    <Setter Property="BorderBrush" Value="#ffd129"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                Background="#00c4b4" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,10">
            <TextBlock x:Name="txtRoleTitle" 
                       Text="Вход как посетитель" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                Background="White" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Поиск товаров" 
                           FontSize="14" 
                           FontWeight="Bold" 
                           Margin="0,0,0,5"/>
                <TextBox x:Name="txtSearch" 
                         TextChanged="SearchBox_TextChanged"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <Border x:Name="ManagerPanel" 
                        Background="White" 
                        CornerRadius="5" 
                        Padding="10" 
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Панель управления" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>

                        <Button Content="Добавить товар" 
                                Click="AddProduct_Click"
                                Background="#00c4b4"
                                Foreground="White"
                                Margin="5"
                                Height="35"/>

                        <Button Content="Удалить выбранный товар" 
                                Click="DeleteSelectedProduct_Click"
                                Background="#00c4b4"
                                Foreground="White"
                                Margin="5"
                                Height="35"/>

                        <Button Content="Управление категориями" 
                                Click="ManageCategories_Click"
                                Background="#00c4b4"
                                Foreground="White"
                                Margin="5"
                                Height="35"/>

                        <Button Content="Управление брендами" 
                                Click="ManageBrands_Click"
                                Background="#00c4b4"
                                Foreground="White"
                                Margin="5"
                                Height="35"/>

                        <Button Content="Управление тегами" 
                                Click="ManageTags_Click"
                                Background="#00c4b4"
                                Foreground="White"
                                Margin="5"
                                Height="35"/>
                    </StackPanel>
                </Border>

                <Border Background="White" 
                        CornerRadius="5" 
                        Padding="10" 
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Сортировка" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>

                        <ComboBox x:Name="cmbSort" 
                                  SelectionChanged="SortComboBox_SelectionChanged">
                            <ComboBoxItem Tag="Name">По наименованию (А-Я)</ComboBoxItem>
                            <ComboBoxItem Tag="PriceAsc">По цене (возрастание)</ComboBoxItem>
                            <ComboBoxItem Tag="PriceDesc">По цене (убывание)</ComboBoxItem>
                            <ComboBoxItem Tag="StockAsc">По количеству (возрастание)</ComboBoxItem>
                            <ComboBoxItem Tag="StockDesc">По количеству (убывание)</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Background="White" 
                        CornerRadius="5" 
                        Padding="10" 
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Категория" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>

                        <ComboBox x:Name="cmbCategory"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="CategoryFilter_SelectionChanged"/>
                    </StackPanel>
                </Border>

                <Border Background="White" 
                        CornerRadius="5" 
                        Padding="10" 
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Бренд" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>

                        <ComboBox x:Name="cmbBrand"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="BrandFilter_SelectionChanged"/>
                    </StackPanel>
                </Border>

                <Border Background="White" 
                        CornerRadius="5" 
                        Padding="10" 
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Цена" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="от" FontSize="12" Margin="0,5,0,0"/>
                        <TextBox x:Name="txtPriceFrom" 
                 >
                            <TextBox.Text>
                                <Binding Path="PriceFrom" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <validation:PriceValidationRule ValidatesOnTargetUpdated="True"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="до" FontSize="12" Margin="0,10,0,0"/>
                        <TextBox x:Name="txtPriceTo" 
                                >
                            <TextBox.Text>
                                <Binding Path="PriceTo" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <validation:PriceValidationRule ValidatesOnTargetUpdated="True"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>
                </Border>

                <Button Content="Сбросить все фильтры" 
                        Click="ResetFilters_Click"
                        Background="#00c4b4"
                        Foreground="White"
                        Height="40"
                        Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Grid.Column="1" 
                Background="White" 
                CornerRadius="5" 
                Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" 
                        Background="#00c4b4" 
                        CornerRadius="3" 
                        Padding="10" 
                        Margin="0,0,0,10">
                    <TextBlock Text="Список товаров" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListView x:Name="ProductsListView"
                              ItemsSource="{Binding ProductsView}"
                              HorizontalContentAlignment="Stretch"
                              Background="Transparent"
                              BorderThickness="0"
                              MouseDoubleClick="ProductsListView_MouseDoubleClick">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,5">
                                            <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Top">
                                                <Run Text="Название товара: "/>
                                                <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                            <TextBlock VerticalAlignment="Top" Margin="0,5,0,0">
                                                <Run Text="★ рейтинг: "/>
                                                <Run Text="{Binding Rating, StringFormat='{}{0:F1}'}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                                   FontSize="16" 
                                                   FontWeight="Bold" 
                                                   HorizontalAlignment="Right" 
                                                   VerticalAlignment="Top"
                                                   Foreground="#00c4b4">
                                            <Run Text="Цена: "/>
                                            <Run Text="{Binding Price, StringFormat='{}{0:C}'}"/>
                                        </TextBlock>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,5">
                                            <TextBlock Margin="0,5" VerticalAlignment="Top">
                                                <Run Text="Категория: "/>
                                                <Run Text="{Binding Category.Name}"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,5" VerticalAlignment="Top" TextWrapping="Wrap">
                                                <Run Text="Описание: "/>
                                                <Run Text="{Binding Description}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Grid.Column="1" 
                                                   HorizontalAlignment="Right" 
                                                   VerticalAlignment="Bottom"
                                                   FontSize="12">
                                            <Run Text="Остаток: "/>
                                            <Run Text="{Binding Stock}"/>
                                            <Run Text=" шт."/>
                                        </TextBlock>

                                        <ItemsControl Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                                      Margin="0,5"
                                                      ItemsSource="{Binding Tags}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#E0E0E0" 
                                                            CornerRadius="10" 
                                                            Padding="8,3" 
                                                            Margin="2">
                                                        <TextBlock>
                                                            <Run Text="#"/>
                                                            <Run Text="{Binding Name}"/>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                Background="White" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,10,0,0">
            <WrapPanel HorizontalAlignment="Center">
                <Border Background="#00c4b4" 
                        CornerRadius="15" 
                        Padding="10,5" 
                        Margin="5">
                    <TextBlock Foreground="White">
                        <Run Text="Всего записей: "/>
                        <Run Text="{Binding Products.Count, Mode=OneWay}"/>
                    </TextBlock>
                </Border>

                <Border Background="#00b4c4" 
                        CornerRadius="15" 
                        Padding="10,5" 
                        Margin="5">
                    <TextBlock Foreground="White">
                        <Run Text="Показано: "/>
                        <Run Text="{Binding ElementName=ProductsListView, Path=Items.Count, Mode=OneWay}"/>
                    </TextBlock>
                </Border>
            </WrapPanel>
        </Border>
    </Grid>
</Window>