<Application x:Class="Практическая__15.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Практическая__15" 
             xmlns:materialDesign1="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <materialDesign1:BundledTheme BaseTheme="Light" PrimaryColor="Teal" SecondaryColor="Cyan"/>

                <ResourceDictionary>
                    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#00c4b4"/>
                    <SolidColorBrush x:Key="SecondaryAccentBrush" Color="#00b4c4"/>
                    <SolidColorBrush x:Key="LowStockBorderBrush" Color="#ffd129"/>
                    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#dfeaeb"/>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                <Setter Property="AutomationProperties.Name" Value="" />
                <Setter Property="Margin" Value="0,5" />
            </Style>

            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignComboBox}">
                <Setter Property="AutomationProperties.Name" Value="" />
                <Setter Property="Margin" Value="0,5" />
            </Style>

            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Margin" Value="5" />
                <Setter Property="Height" Value="35" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
